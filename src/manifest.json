{
	"manifest_version": 3,
	"icons": {
		"16": "icon/16.png",
		"32": "icon/32.png",
		"48": "icon/48.png",
		"96": "icon/96.png",
		"128": "icon/128.png"
	},
	"action": {
		"default_title": "POE2 Extensions"
	},
	"host_permissions": ["https://www.pathofexile.com/*", "https://zetaztt.github.io/*", "https://web.poecdn.com/*"],
	"permissions": ["scripting", "storage", "tabs", "sidePanel"],
	"background": {
		"service_worker": "src/background.ts"
	},
	"side_panel": {
		"default_path": "src/sidepanel/index.html"
	},
	"content_scripts": [
		{
			"matches": ["https://www.pathofexile.com/trade2*"],
			"run_at": "document_start",
			"js": ["src/trade/trade-content.ts"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": [
				"src/trade/item-code/trade-item-code-inject.js",
				"src/trade/stat-preset/trade-stat-preset-inject.js"
			],
			"matches": ["https://www.pathofexile.com/*"]
		}
	]
}
