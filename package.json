{
	"name": "zeta-poe2-extensions",
	"description": "manifest.json description",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"workspaces": [
		"packages/trade-translate-tools"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"compile": "vue-tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"pull-trade-texts": "tsx ./scripts/translate/pull-trade-texts.ts",
		"pull-translate": "npm run pull-trade-texts",
		"build-translate": "tsx ./scripts/translate/build-translate.ts"
	},
	"dependencies": {
		"ajax-hook": "^3.0.3",
		"vue": "^3.5.29",
		"webextension-polyfill": "^0.12.0"
	},
	"devDependencies": {
		"@types/chrome": "^0.2.2",
		"@types/node": "^25.9.2",
		"@types/webextension-polyfill": "^0.12.5",
		"@vitejs/plugin-vue": "^6.0.7",
		"prettier": "^3.8.4",
		"typescript": "^5.9.3",
		"vite": "^8.0.16",
		"vite-plugin-web-extension": "^4.5.1",
		"vue-tsc": "^3.2.5",
		"tsx": "^4.22.4"
	}
